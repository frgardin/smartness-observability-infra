{
  "title": "Fleet Overview",
  "uid": "fleet-overview",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Todas as máquinas",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 100 },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "red", "value": 80 }
                ]
              }},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM Usada" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM Total" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk % (/)" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.width", "value": 110 },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 70 },
                  { "color": "red", "value": 85 }
                ]
              }},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              { "id": "mappings", "value": [
                { "type": "value", "options": {
                  "1": { "text": "UP", "color": "green" },
                  "0": { "text": "DOWN", "color": "red" }
                }}
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "instance", "desc": false }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", job=\"node\"}[1m])) * 100)",
          "refId": "A",
          "legendFormat": "{{instance}}",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node\"} - node_memory_MemAvailable_bytes{job=\"node\"}",
          "refId": "B",
          "legendFormat": "{{instance}}",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"node\"}",
          "refId": "C",
          "legendFormat": "{{instance}}",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (node_filesystem_avail_bytes{job=\"node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node\", mountpoint=\"/\"} * 100)",
          "refId": "D",
          "legendFormat": "{{instance}}",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"node\"}",
          "refId": "E",
          "legendFormat": "{{instance}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "CPU %",
              "Value #B": "RAM Usada",
              "Value #C": "RAM Total",
              "Value #D": "Disk % (/)",
              "Value #E": "Status",
              "instance": "Máquina"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "hostname": true
            },
            "indexByName": {
              "Máquina": 0,
              "Status": 1,
              "CPU %": 2,
              "RAM Usada": 3,
              "RAM Total": 4,
              "Disk % (/)": 5
            }
          }
        }
      ]
    }
  ]
}
